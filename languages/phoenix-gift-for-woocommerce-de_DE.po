msgid "Always"
msgstr "Immer"

#: src/Admin/Rules_Admin.php:953
msgid "Any cart value"
msgstr "Beliebiger Warenkorbwert"

#: src/Admin/Rules_Admin.php:941
msgid "Any item in cart"
